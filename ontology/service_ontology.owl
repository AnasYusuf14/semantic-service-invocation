<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/ontologies/service-ontology"
         xmlns="http://www.semanticweb.org/ontologies/service-ontology#">

<owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/service-ontology">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LLM-Based Semantic Service Invocation Ontology</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OWL ontology for semantic service invocation across Weather, Travel, Product, Order, and Calendar domains.</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#hasOperation">
  <rdfs:domain rdf:resource="#ServiceDomain"/>
  <rdfs:range rdf:resource="#Operation"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasOperation</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a ServiceDomain to its Operations.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEndpoint">
  <rdfs:domain rdf:resource="#Operation"/>
  <rdfs:range rdf:resource="#Endpoint"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasEndpoint</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links an Operation to its Endpoint.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasParameter">
  <rdfs:domain rdf:resource="#Operation"/>
  <rdfs:range rdf:resource="#Parameter"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasParameter</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links an Operation to its Parameters.</rdfs:comment>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#operationId">
  <rdfs:domain rdf:resource="#Operation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">operationId</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The operationId from the OpenAPI specification.</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#httpMethod">
  <rdfs:domain rdf:resource="#Endpoint"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">httpMethod</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HTTP method (GET or POST).</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#endpointPath">
  <rdfs:domain rdf:resource="#Endpoint"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">endpointPath</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The URL path of the endpoint.</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#parameterName">
  <rdfs:domain rdf:resource="#Parameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">parameterName</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The parameter name from the OpenAPI specification.</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#parameterType">
  <rdfs:domain rdf:resource="#Parameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">parameterType</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The schema type of the parameter (string, integer, number).</rdfs:comment>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#isRequired">
  <rdfs:domain rdf:resource="#Parameter"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">isRequired</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Whether the parameter is required.</rdfs:comment>
</owl:DatatypeProperty>

<owl:Class rdf:about="#ServiceDomain">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ServiceDomain</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A domain grouping related API operations.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Operation">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Operation</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An API operation identified by its operationId.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Endpoint">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endpoint</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An HTTP endpoint associated with an operation.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Parameter">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parameter</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A query parameter accepted by an operation.</rdfs:comment>
</owl:Class>

<owl:NamedIndividual rdf:about="#Weather">
