<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns="http://www.semanticweb.org/ontologies/service-ontology#"
     xml:base="http://www.semanticweb.org/ontologies/service-ontology">

    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/service-ontology">
        <rdfs:label>LLM-Based Semantic Service Invocation Ontology</rdfs:label>
        <rdfs:comment>OWL ontology for semantic service invocation across Weather, Travel, Product, Order, and Calendar domains.</rdfs:comment>
    </owl:Ontology>

    <!-- ================================================================ -->
    <!--  Classes                                                          -->
    <!-- ================================================================ -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain">
        <rdfs:label>ServiceDomain</rdfs:label>
        <rdfs:comment>A domain grouping related API operations.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Operation">
        <rdfs:label>Operation</rdfs:label>
        <rdfs:comment>An API operation identified by its operationId.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Endpoint">
        <rdfs:label>Endpoint</rdfs:label>
        <rdfs:comment>An HTTP endpoint associated with an operation.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Parameter">
        <rdfs:label>Parameter</rdfs:label>
        <rdfs:comment>A query parameter accepted by an operation.</rdfs:comment>
    </owl:Class>

    <!-- ================================================================ -->
    <!--  Object Properties                                                -->
    <!-- ================================================================ -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#hasOperation">
        <rdfs:label>hasOperation</rdfs:label>
        <rdfs:comment>Links a ServiceDomain to its Operations.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:range  rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#hasEndpoint">
        <rdfs:label>hasEndpoint</rdfs:label>
        <rdfs:comment>Links an Operation to its Endpoint.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:range  rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#hasParameter">
        <rdfs:label>hasParameter</rdfs:label>
        <rdfs:comment>Links an Operation to its Parameters.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:range  rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
    </owl:ObjectProperty>

    <!-- ================================================================ -->
    <!--  Data Properties                                                  -->
    <!-- ================================================================ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#operationId">
        <rdfs:label>operationId</rdfs:label>
        <rdfs:comment>The operationId from the OpenAPI specification.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#httpMethod">
        <rdfs:label>httpMethod</rdfs:label>
        <rdfs:comment>HTTP method (GET or POST).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#endpointPath">
        <rdfs:label>endpointPath</rdfs:label>
        <rdfs:comment>The URL path of the endpoint.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#parameterName">
        <rdfs:label>parameterName</rdfs:label>
        <rdfs:comment>The parameter name from the OpenAPI specification.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#parameterType">
        <rdfs:label>parameterType</rdfs:label>
        <rdfs:comment>The schema type of the parameter (string, integer, number).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/service-ontology#isRequired">
        <rdfs:label>isRequired</rdfs:label>
        <rdfs:comment>Whether the parameter is required.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>

    <!-- ================================================================ -->
    <!--  Service Domain Individuals                                       -->
    <!-- ================================================================ -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Weather">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:label>Weather</rdfs:label>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetForecast"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetAirQuality"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeed"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Travel">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:label>Travel</rdfs:label>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#BookFlight"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CancelFlight"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchHotel"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#BookHotel"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Product">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:label>Product</rdfs:label>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchProduct"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetProductDetails"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CompareProducts"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CheckProductAvailability"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetProductReviews"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Order">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:label>Order</rdfs:label>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CreateOrder"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CancelOrder"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#TrackOrder"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ReturnOrder"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetOrderDetails"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#Calendar">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ServiceDomain"/>
        <rdfs:label>Calendar</rdfs:label>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CreateMeeting"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CancelMeeting"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#UpdateMeeting"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CheckAvailability"/>
        <hasOperation rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#ListEvents"/>
    </owl:NamedIndividual>

    <!-- ================================================================ -->
    <!--  Weather Operations                                               -->
    <!-- ================================================================ -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>GetCurrentWeather</rdfs:label>
        <operationId>GetCurrentWeather</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeatherEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather_city"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather_unit"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeatherEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>GetCurrentWeatherEndpoint</rdfs:label>
        <endpointPath>/weather/current</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather_city">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetCurrentWeather_city</rdfs:label>
        <parameterName>city</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetCurrentWeather_unit">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetCurrentWeather_unit</rdfs:label>
        <parameterName>unit</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetForecast">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>GetForecast</rdfs:label>
        <operationId>GetForecast</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetForecastEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_city"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_date"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_unit"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetForecastEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>GetForecastEndpoint</rdfs:label>
        <endpointPath>/weather/forecast</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_city">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetForecast_city</rdfs:label>
        <parameterName>city</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_date">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetForecast_date</rdfs:label>
        <parameterName>date</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetForecast_unit">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetForecast_unit</rdfs:label>
        <parameterName>unit</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetAirQuality">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>GetAirQuality</rdfs:label>
        <operationId>GetAirQuality</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetAirQualityEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetAirQuality_city"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetAirQualityEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>GetAirQualityEndpoint</rdfs:label>
        <endpointPath>/weather/air-quality</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetAirQuality_city">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetAirQuality_city</rdfs:label>
        <parameterName>city</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>GetTemperature</rdfs:label>
        <operationId>GetTemperature</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetTemperatureEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature_city"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature_unit"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetTemperatureEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>GetTemperatureEndpoint</rdfs:label>
        <endpointPath>/weather/temperature</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature_city">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetTemperature_city</rdfs:label>
        <parameterName>city</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetTemperature_unit">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetTemperature_unit</rdfs:label>
        <parameterName>unit</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeed">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>GetWindSpeed</rdfs:label>
        <operationId>GetWindSpeed</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeedEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeed_city"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeedEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>GetWindSpeedEndpoint</rdfs:label>
        <endpointPath>/weather/wind</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#GetWindSpeed_city">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>GetWindSpeed_city</rdfs:label>
        <parameterName>city</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <!-- ================================================================ -->
    <!--  Travel Operations                                                -->
    <!-- ================================================================ -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>SearchFlight</rdfs:label>
        <operationId>SearchFlight</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchFlightEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_from"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_to"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_date"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#SearchFlightEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>SearchFlightEndpoint</rdfs:label>
        <endpointPath>/travel/flights/search</endpointPath>
        <httpMethod>GET</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_from">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>SearchFlight_from</rdfs:label>
        <parameterName>from</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_to">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>SearchFlight_to</rdfs:label>
        <parameterName>to</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#SearchFlight_date">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>SearchFlight_date</rdfs:label>
        <parameterName>date</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#BookFlight">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>BookFlight</rdfs:label>
        <operationId>BookFlight</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#BookFlightEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#BookFlight_flightId"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#BookFlight_passengerName"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#BookFlightEndpoint">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Endpoint"/>
        <rdfs:label>BookFlightEndpoint</rdfs:label>
        <endpointPath>/travel/flights/book</endpointPath>
        <httpMethod>POST</httpMethod>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#BookFlight_flightId">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>BookFlight_flightId</rdfs:label>
        <parameterName>flightId</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#BookFlight_passengerName">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Parameter"/>
        <rdfs:label>BookFlight_passengerName</rdfs:label>
        <parameterName>passengerName</parameterName>
        <parameterType>string</parameterType>
        <isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isRequired>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#CancelFlight">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#Operation"/>
        <rdfs:label>CancelFlight</rdfs:label>
        <operationId>CancelFlight</operationId>
        <hasEndpoint rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CancelFlightEndpoint"/>
        <hasParameter rdf:resource="http://www.semanticweb.org/ontologies/service-ontology#CancelFlight_bookingId"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologies/service-ontology#CancelFlightEndpoint">
