  <hasOperation rdf:resource="#GetForecast"/>
  <hasOperation rdf:resource="#GetAirQuality"/>
  <hasOperation rdf:resource="#GetTemperature"/>
  <hasOperation rdf:resource="#GetWindSpeed"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weather</rdfs:label>
</owl:NamedIndividual>

